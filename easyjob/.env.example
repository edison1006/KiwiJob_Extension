# API
# Quick local dev (no Postgres): SQLite file under apps/api/data/
DATABASE_URL=sqlite:///./data/easyjob.db

# Docker / production Postgres (create role+db first, or use docker compose):
# DATABASE_URL=postgresql+psycopg2://easyjob:easyjob@localhost:5432/easyjob

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MOCK_USER_ID=1
RESUME_STORAGE_DIR=./data/resumes

# development | staging | production
ENVIRONMENT=development

# CORS: use * for local dev (web + Chrome extension). For production, set explicit https:// origins and each
# chrome-extension://<id> once you know the store / unpacked extension id (comma-separated). Avoid * in production.
CORS_ORIGINS=*

# Web / Extension (set in apps/web/.env.local and extension storage)
VITE_API_URL=http://localhost:8000
