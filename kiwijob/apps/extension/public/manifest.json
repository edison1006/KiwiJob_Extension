{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "KiwiJob",
  "description": "Save job postings, track applications, and run CV match analysis with KiwiJob.",
  "version": "0.2.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "KiwiJob — toggle sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab", "sidePanel", "tabs"],
  "side_panel": {
    "default_path": "page-sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-sidebar.html",
        "page-sidebar.js",
        "sidepanel.html",
        "assets/*",
        "chunks/*",
        "kiwijob-logo.png",
        "kiwijob-mark.png",
        "icons/icon-16.png",
        "icons/icon-32.png",
        "icons/icon-48.png",
        "icons/icon-128.png"
      ],
      "matches": [
        "https://*.seek.co.nz/*",
        "https://*.seek.com.au/*",
        "https://*.seek.com/*",
        "https://*.linkedin.com/*",
        "https://*.trademe.co.nz/*",
        "https://*.indeed.com/*",
        "https://*.indeed.co.nz/*",
        "https://nz.jora.com/*",
        "https://jobs.govt.nz/*",
        "https://careers.govt.nz/*",
        "https://*.studentjobsearch.co.nz/*",
        "https://*.sjs.co.nz/*",
        "https://*.myjobspace.co.nz/*",
        "https://*.job.co.nz/*",
        "https://*.kiwihealthjobs.com/*",
        "https://*.maoripacificjobs.co.nz/*",
        "https://*.workingin-newzealand.com/*",
        "https://*.workingin.com/*",
        "https://*.talent.com/*",
        "https://*.careerjet.co.nz/*",
        "https://*.adzuna.co.nz/*",
        "https://*.jobted.co.nz/*",
        "https://*.recruit.net/*",
        "https://*.glassdoor.co.nz/*",
        "https://*.whatjobs.com/*",
        "https://*.grabjobs.co/*",
        "https://*.workhere.co.nz/*",
        "https://*.seasonaljobs.co.nz/*",
        "https://*.backpackerboard.co.nz/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.ashbyhq.com/*",
        "https://*.workable.com/*",
        "https://*.bamboohr.com/*",
        "https://*.breezy.hr/*",
        "https://*.jobvite.com/*",
        "https://*.recruitee.com/*",
        "https://*.successfactors.com/*",
        "https://*.jobs2web.com/*",
        "https://*.oraclecloud.com/*",
        "https://*.taleo.net/*"
      ]
    }
  ],
  "host_permissions": [
    "https://d3qngwzf3gjrpb.cloudfront.net/*",
    "https://*.seek.co.nz/*",
    "https://*.seek.com.au/*",
    "https://*.seek.com/*",
