{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "KiwiJob",
  "description": "Save job postings, track applications, and run CV match analysis with KiwiJob.",
  "version": "0.1.2",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "KiwiJob — toggle sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab", "sidePanel", "contextMenus"],
  "side_panel": {
    "default_path": "page-sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-sidebar.html",
        "page-sidebar.js",
        "sidepanel.html",
        "assets/*",
        "chunks/*",
        "kiwijob-logo.png",
        "kiwijob-mark.png",
        "icons/icon-16.png",
        "icons/icon-32.png",
        "icons/icon-48.png",
        "icons/icon-128.png"
      ],
      "matches": [
        "https://*.seek.co.nz/*",
        "https://*.seek.com.au/*",
        "https://*.linkedin.com/*",
        "https://*.trademe.co.nz/*",
        "https://*.indeed.com/*"
      ]
    }
  ],
  "commands": {
    "kiwijob-autofill": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Fill application form with KiwiJob profile"
    }
  },
  "host_permissions": [
    "https://*.seek.co.nz/*",
    "https://*.seek.com.au/*",
    "https://*.linkedin.com/*",
    "https://*.trademe.co.nz/*",
    "https://*.indeed.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.seek.co.nz/*",
        "https://*.seek.com.au/*",
        "https://*.linkedin.com/*",
        "https://*.trademe.co.nz/*",
        "https://*.indeed.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
